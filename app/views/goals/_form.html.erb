<%= form_with model: goal, builder: MaterialFormBuilder, data: { controller: 'material-form' }, id: :form do |f| %>
  <div class="pb-4">
    <%= f.text_field :name %>
  </div>
  <div class="pb-4">
    <%= f.number_field :amount %>
  </div>
  <div class="pb-4">
    <%= f.date_field :target_date, min: 1.day.from_now, class: 'w-full' %>
  </div>
  <%= f.select :recurrance, Goal::RECURRANCES.map { |r| [r, r] } %>

  <div class="mdc-dialog__actions">
    <div class='mdc-touch-target-wrapper' data-material-form-target="button">
      <button type="button" class="mdc-button mdc-dialog__button" data-mdc-dialog-action="close" >
        <div class="mdc-button__ripple"></div>
        <span class="mdc-button__label">Cancel</span>
      </button>
    </div>
    <button formnovalidate type="submit" class="mdc-button mdc-dialog__button">
      <div class="mdc-button__ripple"></div>
      <span class="mdc-button__label">Save</span>
    </button>
  </div>
<% end %>
